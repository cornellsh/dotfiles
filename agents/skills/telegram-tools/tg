#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["telethon>=1.42,<2"]
# ///
"""Minimal Telegram CLI for coding agents.

Uses a Telethon StringSession. Credentials are read from the environment:
  TELEGRAM_API_ID, TELEGRAM_API_HASH, TELEGRAM_SESSION_STRING
If those are not set, ~/.zsh_secrets is parsed for `export TELEGRAM_*=...` lines.

Commands:
  tg me                                 Show the logged-in account
  tg chats [--limit N] [--archived]     List recent conversations (default 20)
  tg read <chat> [--limit N]            Read recent messages (default 20)
  tg send <chat> <text>                 Send a message
  tg reply <chat> <msg_id> <text>       Reply to a specific message
  tg search <query> [--limit N]         Global message search (default 20)
  tg search <query> --chat <chat>       Search within one chat

<chat> may be: @username, a numeric id, a phone number, "me" (Saved Messages),
or a (case-insensitive) substring of a dialog title.

Output is plain text, one item per block, optimized for low token use.
Add --json to any read/list command for machine-readable output.
"""
import argparse
import asyncio
import json
import logging
import os
import re
import sys
from pathlib import Path

logging.disable(logging.CRITICAL)  # silence telethon connection chatter

from telethon import TelegramClient  # noqa: E402
from telethon.sessions import StringSession  # noqa: E402


def _load_secrets():
    needed = ("TELEGRAM_API_ID", "TELEGRAM_API_HASH", "TELEGRAM_SESSION_STRING")
    if all(os.environ.get(k) for k in needed):
        return
    secrets = Path.home() / ".zsh_secrets"
    if not secrets.exists():
        return
    pat = re.compile(r'^\s*export\s+(TELEGRAM_[A-Z_]+)=([\'"]?)(.*?)\2\s*$')
    for line in secrets.read_text().splitlines():
        m = pat.match(line)
        if m and not os.environ.get(m.group(1)):
            os.environ[m.group(1)] = m.group(3)


def _die(msg, code=1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


async def _client():
    _load_secrets()
    try:
        api_id = int(os.environ["TELEGRAM_API_ID"])
        api_hash = os.environ["TELEGRAM_API_HASH"]
        session = os.environ["TELEGRAM_SESSION_STRING"]
    except KeyError as e:
        _die(f"missing credential {e}. Set TELEGRAM_API_ID/API_HASH/SESSION_STRING "
             f"or add them to ~/.zsh_secrets")
    c = TelegramClient(StringSession(session), api_id, api_hash)
    await c.connect()
    if not await c.is_user_authorized():
        _die("session not authorized (bad or expired TELEGRAM_SESSION_STRING)")
    return c


async def _resolve(c, ref):
    if ref == "me":
        return "me"
    if re.fullmatch(r"-?\d+", ref):
        return int(ref)
    if ref.startswith("@") or ref.startswith("+"):
        return ref
    try:
        return await c.get_entity(ref)
    except Exception:
        pass
    # fall back to substring match against dialog titles
    ref_l = ref.lower()
    async for d in c.iter_dialogs():
        if d.name and ref_l in d.name.lower():
            return d.entity
    _die(f"could not resolve chat: {ref!r}")


def _name(entity):
    for attr in ("title", "first_name", "username"):
        v = getattr(entity, attr, None)
        if v:
            return v
    return str(getattr(entity, "id", entity))


async def cmd_me(c, args):
    me = await c.get_me()
    if args.json:
        print(json.dumps({"id": me.id, "first_name": me.first_name,
                          "last_name": me.last_name, "username": me.username,
                          "phone": me.phone}))
    else:
        print(f"{me.first_name or ''} {me.last_name or ''}".strip()
              + f"  @{me.username}" if me.username else "")
        print(f"id: {me.id}")


async def cmd_chats(c, args):
    out = []
    async for d in c.iter_dialogs(limit=args.limit, archived=args.archived):
        out.append({
            "id": d.id,
            "name": d.name,
            "unread": d.unread_count,
            "kind": ("channel" if d.is_channel else "group" if d.is_group else "user"),
        })
    if args.json:
        print(json.dumps(out, ensure_ascii=False, indent=2))
    else:
        for d in out:
            flag = f"  ({d['unread']} unread)" if d["unread"] else ""
            print(f"[{d['kind']}] {d['name']}  id={d['id']}{flag}")


async def _print_messages(c, entity, messages, as_json):
    rows = []
    for m in messages:
        sender = ""
        try:
            s = await m.get_sender()
            if s:
                sender = _name(s)
        except Exception:
            pass
        rows.append({
            "id": m.id,
            "date": m.date.isoformat() if m.date else None,
            "from": sender,
            "text": m.text or ("<media>" if m.media else ""),
        })
    if as_json:
        print(json.dumps(rows, ensure_ascii=False, indent=2))
    else:
        for r in reversed(rows):  # oldest first for readability
            ts = (r["date"] or "")[:16].replace("T", " ")
            print(f"[{r['id']}] {ts} {r['from']}: {r['text']}")


async def cmd_read(c, args):
    entity = await _resolve(c, args.chat)
    msgs = await c.get_messages(entity, limit=args.limit)
    await _print_messages(c, entity, msgs, args.json)


async def cmd_send(c, args):
    entity = await _resolve(c, args.chat)
    m = await c.send_message(entity, args.text)
    print(f"sent (id={m.id}) to {args.chat}")


async def cmd_sendfile(c, args):
    entity = await _resolve(c, args.chat)
    m = await c.send_file(entity, args.path, caption=args.caption or "",
                          force_document=True)
    print(f"sent file (id={m.id}) to {args.chat}")


async def cmd_reply(c, args):
    entity = await _resolve(c, args.chat)
    m = await c.send_message(entity, args.text, reply_to=args.msg_id)
    print(f"replied (id={m.id}) to msg {args.msg_id} in {args.chat}")


async def cmd_search(c, args):
    entity = await _resolve(c, args.chat) if args.chat else None
    msgs = await c.get_messages(entity, limit=args.limit, search=args.query)
    await _print_messages(c, entity, msgs, args.json)


def build_parser():
    p = argparse.ArgumentParser(prog="tg", description="Minimal Telegram CLI")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("me", help="show logged-in account")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_me)

    sp = sub.add_parser("chats", help="list recent conversations")
    sp.add_argument("--limit", type=int, default=20)
    sp.add_argument("--archived", action="store_true")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_chats)

    sp = sub.add_parser("read", help="read recent messages from a chat")
    sp.add_argument("chat")
    sp.add_argument("--limit", type=int, default=20)
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_read)

    sp = sub.add_parser("send", help="send a message")
    sp.add_argument("chat")
    sp.add_argument("text")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_send)

    sp = sub.add_parser("sendfile", help="send a file as a document")
    sp.add_argument("chat")
    sp.add_argument("path")
    sp.add_argument("--caption", default="")
    sp.set_defaults(fn=cmd_sendfile)

    sp = sub.add_parser("reply", help="reply to a message")
    sp.add_argument("chat")
    sp.add_argument("msg_id", type=int)
    sp.add_argument("text")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_reply)

    sp = sub.add_parser("search", help="search messages")
    sp.add_argument("query")
    sp.add_argument("--chat", default=None)
    sp.add_argument("--limit", type=int, default=20)
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_search)
    return p


async def _run(args):
    c = await _client()
    try:
        await args.fn(c, args)
    finally:
        await c.disconnect()


def main():
    args = build_parser().parse_args()
    asyncio.run(_run(args))


if __name__ == "__main__":
    main()
